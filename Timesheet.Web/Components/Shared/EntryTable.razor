@using Timesheet.Core.Models

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Date</th>
            <th>Project</th>
            <th>Hours</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var entry in Entries)
        {
            <tr>
                <td>@entry.Date.ToString("dd/MM/yyyy")</td>
                <td>@entry.ProjectId</td>
                <td>@entry.HoursWorked</td>
                <td>@entry.Description</td>
                <td>
                    <button class="btn btn-warning btn-sm me-1" @onclick="() => OnEdit.InvokeAsync(entry.Id)">Edit</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => OnDelete.InvokeAsync(entry.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter] public IEnumerable<TimesheetEntry> Entries { get; set; } = Enumerable.Empty<TimesheetEntry>();
    [Parameter] public EventCallback<Guid> OnEdit { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }
}
