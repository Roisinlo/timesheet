@using Timesheet.Core.Models

<div class="mb-3">
    <label class="form-label">User ID</label>
    <input type="text" class="form-control" @bind="Entry.UserId" disabled="@IsEdit" />
</div>

<div class="mb-3">
    <label class="form-label">Project ID</label>
    <input type="text" class="form-control" @bind="Entry.ProjectId" />
</div>

<div class="mb-3">
    <label class="form-label">Date</label>
    <input type="date" class="form-control" @bind="Entry.Date" />
</div>

<div class="mb-3">
    <label class="form-label">Hours Worked</label>
    <input type="number" step="0.5" class="form-control" @bind="Entry.HoursWorked" />
</div>

<div class="mb-3">
    <label class="form-label">Description</label>
    <input type="text" class="form-control" @bind="Entry.Description" />
</div>

<button class="btn btn-primary me-2" @onclick="() => OnSave.InvokeAsync(Entry)">Save</button>
<button class="btn btn-secondary" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@code {
    [Parameter] public TimesheetEntry Entry { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; } = false;
    [Parameter] public EventCallback<TimesheetEntry> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
}
